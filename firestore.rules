rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // - uid: string (required)
    // - name: string (required)
    // - email: string (required)
    // - role: string (required, enum: student, lecturer, admin)
    // - createdAt: string (required)
    //
    // Collection: courses
    // - id: string (required)
    // - lecturerId: string (required)
    // - lecturerName: string (required)
    // - title: string (required)
    // - description: string (optional)
    // - createdAt: string (required)
    //
    // Collection: assignments
    // - id: string (required)
    // - courseId: string (required)
    // - courseTitle: string (required)
    // - title: string (required)
    // - description: string (required)
    // - deadline: string (required)
    // - createdAt: string (required)
    //
    // Collection: submissions
    // - id: string (required)
    // - assignmentId: string (required)
    // - studentId: string (required)
    // - studentName: string (required)
    // - content: string (required)
    // - fileUrl: string (optional)
    // - status: string (required, enum: submitted, pending)
    // - createdAt: string (required)
    //
    // Collection: attendance
    // - id: string (required)
    // - studentId: string (required)
    // - studentName: string (required)
    // - courseId: string (required)
    // - date: string (required)
    // - status: string (required, enum: Present, Absent)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin') || (request.auth.token.email == "omekechinonso71@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt']) &&
             data.uid is string && data.name is string && data.email is string &&
             data.role in ['student', 'lecturer', 'admin'] &&
             data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['lecturerId', 'lecturerName', 'title', 'createdAt']) &&
             data.lecturerId is string && data.title is string &&
             data.title.size() > 0 && data.title.size() < 200;
    }

    function isValidAssignment(data) {
      return data.keys().hasAll(['courseId', 'courseTitle', 'title', 'description', 'deadline', 'createdAt']) &&
             data.courseId is string && data.title is string && data.deadline is string;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['assignmentId', 'studentId', 'studentName', 'content', 'status', 'createdAt']) &&
             data.assignmentId is string && data.studentId is string &&
             data.status in ['submitted', 'pending'];
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['studentId', 'studentName', 'courseId', 'date', 'status']) &&
             data.studentId is string && data.courseId is string &&
             data.status in ['Present', 'Absent'];
    }

    // Rules
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if (isOwner(uid) || isAdmin()) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
    }

    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow create: if hasRole('lecturer') && isValidCourse(request.resource.data) && request.resource.data.lecturerId == request.auth.uid;
      allow update, delete: if (isAuthenticated() && resource.data.lecturerId == request.auth.uid) || isAdmin();
    }

    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow create: if hasRole('lecturer') && isValidAssignment(request.resource.data);
      allow update, delete: if (isAuthenticated() && get(/databases/$(database)/documents/courses/$(resource.data.courseId)).data.lecturerId == request.auth.uid) || isAdmin();
    }

    match /submissions/{submissionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.studentId || hasRole('lecturer') || isAdmin());
      allow create: if hasRole('student') && isValidSubmission(request.resource.data) && request.resource.data.studentId == request.auth.uid;
      allow update: if isOwner(resource.data.studentId) && isValidSubmission(request.resource.data) && request.resource.data.studentId == resource.data.studentId;
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.studentId || hasRole('lecturer') || isAdmin());
      allow create: if hasRole('student') && isValidAttendance(request.resource.data) && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if hasRole('lecturer') || isAdmin();
    }
  }
}
